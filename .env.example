# llama.cpp servers — chạy NATIVE trên host (llama-server đã cài qua Homebrew)
# Từ bên trong Docker container: dùng host.docker.internal
# Từ host trực tiếp: dùng localhost
LLAMACPP_CHAT_URL=http://host.docker.internal:8080/v1
LLAMACPP_EMBED_URL=http://host.docker.internal:8081/v1

# API key — "llama-cpp" cho local llama-server (bất kỳ non-empty string)
# Đổi thành key thật khi dùng OpenAI / Groq / Together / vLLM cloud
LLM_API_KEY=llama-cpp

# Model names
GGUF_CHAT_MODEL=Qwen3.5-9B.Q6_K.gguf
GGUF_EMBED_MODEL=nomic-embed-text-v1.5.Q4_K_M.gguf

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=nexus_docs

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
